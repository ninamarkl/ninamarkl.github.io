@InProceedings{MarklEtAl2023Automatictranscriptiondestandardisation,
  author    = {Nina Markl and Electra Wallington and Ondrej Klejch and Thomas Reitmaier and Gavin Bailey and Jennifer Pearson and Matt Jones and Simon Robinson and Peter Bell},
  booktitle = {Proceedings - SIGUL 2023, 2nd Annual Meeting of the Special Interest Group on Under-resourced Languages},
